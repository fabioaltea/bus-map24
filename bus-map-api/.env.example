
DATABASE_URL=postgresql://busmap:busmap@localhost:5432/busmapdb
REDIS_URL=redis://localhost:6379
MOBILITY_DB_REFRESH_TOKEN=your_refresh_token_here
PMTILES_OUTPUT_DIR=./tiles
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
FEED_REFRESH_CRON=0 2 * * 1
MAX_DOWNLOAD_WORKERS=3
PIPELINE_VERSION=2
# In production, set to your Vercel domain(s). Comma-separated for multiple. Use * to allow all origins.
CORS_ORIGIN=*
# Admin UI authentication
ADMIN_PASSWORD=changeme
# Min 32-char random string — generate with: openssl rand -hex 32
JWT_SECRET=dev-secret-min-32-chars-long-1234
